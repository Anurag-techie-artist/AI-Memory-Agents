    {
      "parameters": {
        "content": "Setting Up the Goal of the Agent using The Chat Trigger\n",
        "height": 80,
        "width": 192
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -32,
